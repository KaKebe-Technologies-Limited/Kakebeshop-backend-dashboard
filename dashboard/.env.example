# ntfy Notification Configuration
# Subscribe to notifications at: https://ntfy.sh/kakebe-notifications
VITE_NTFY_URL=https://ntfy.sh
VITE_NTFY_TOPIC=kakebe-notifications

# Email Notification Configuration (Optional)
# VITE_EMAIL_API_KEY=your_email_api_key
# VITE_EMAIL_FROM=noreply@kakebe.shop

# SMS Notification Configuration (Optional)
# VITE_SMS_API_KEY=your_sms_api_key
# VITE_SMS_FROM=+1234567890

# Backend API Base URL
VITE_API_BASE_URL=https://backend.kakebeshop.com
VITE_BACKEND_URL=https://backend.kakebeshop.com

# Order Monitor Cron Credentials (for serverless order notifications)
# These must be admin credentials that have access to /api/v1/admin/orders/
ADMIN_EMAIL=your_admin_email@kakebe.com
ADMIN_PASSWORD=your_admin_password
